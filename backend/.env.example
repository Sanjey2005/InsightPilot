# InsightPilot — Backend environment variables
# ─────────────────────────────────────────────
# 1. Copy:   cp backend/.env.example backend/.env
# 2. Fill in GEMINI_API_KEY (all other values have safe defaults for local dev)
# 3. Start:  uvicorn main:app --reload --port 8000

# ── LLM ───────────────────────────────────────────────────────────────────
# Required for the AI pipeline (schema classification, SQL generation,
# insight narratives, chart config). Get a free key at:
#   https://aistudio.google.com → "Get API key" → "Create API key"
GEMINI_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────
# SQLite by default — file is created automatically in backend/ on first run.
# For production swap to: postgresql://user:pass@host:5432/insightpilot
DATABASE_URL=sqlite:///./insightpilot.db

# ── Auth ──────────────────────────────────────────────────────────────────
# DEV_MODE=true skips JWT validation and uses a fixed internal dev user.
# Safe for local development — set to false and provide Supabase credentials
# only when deploying to production.
DEV_MODE=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Upload limits ─────────────────────────────────────────────────────────
MAX_CSV_SIZE_MB=50
